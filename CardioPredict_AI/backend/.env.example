# CardioPredict AI — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to GitHub

# Path to your trained model file (.h5 or .pkl)
MODEL_PATH=model/cardio_model.h5

# Path to your fitted scaler
SCALER_PATH=model/scaler.pkl

# Port to run the Flask server on (default: 5000)
PORT=5000

# Set to true only during local development
FLASK_DEBUG=false

# Allowed CORS origins — set to your Netlify URL in production
# Example: https://cardiopredict.netlify.app
ALLOWED_ORIGINS=*
